# Source - https://stackoverflow.com/a/27570751
# Posted by MrFlick
# Retrieved 2026-04-21, License - CC BY-SA 3.0
r <- 0.618
n <- 10000
re <- sqrt(1-r*r);
x <- rnorm(n);
y <- x*r+rnorm(n)*re
y[x<0] <- -y[x<0];
par(mar=rep(0,4))
plot(x,y, col=rgb(1,0,1), axes=F, asp=1)
